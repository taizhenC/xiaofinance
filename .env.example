# DeepSeek API (leave empty for keyless fallback = quotes only, no summaries)
DEEPSEEK_API_KEY=

LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
SUMMARY_LANG=en

# Crawl
# DISCOVERY_CORE runs every cycle; DISCOVERY_POOL is rotated KEYWORDS_PER_CYCLE at a time
# so a day's cycles cover sectors one cycle can't afford. Leave DISCOVERY_POOL empty to
# fall back to the old static DISCOVERY_KEYWORDS list.
#
# Measure a keyword before adding it (python -m app.probe --keywords "美股医药,黄金股"):
# index terms return 定投/ETF diaries and bare sector terms return A-share posts, and
# neither names a US stock the pipeline can extract — 73 of the first 98 notes crawled
# named none at all.
DISCOVERY_CORE=美股,美股财报
# Measured hit rates: 巴菲特 92%, 美股财报 67%, 中概股 62%, 美股医药 (low volume but on-topic),
# 美股银行 33%, 美股打新 (all IPO posts). Rejected by probe: 电动车 0% (scooter rentals),
# 减肥药 0% (diet pills), 黄金股 17% (A-share gold), 能源股 (A-share 新能源), 纳指/标普500
# (定投/ETF diaries that name no company).
DISCOVERY_POOL=中概股,美股医药,美股银行,巴菲特,美股打新
# Each keyword now runs as its own crawler process with KEYWORD_GAP_MIN of silence in
# between, so the cycle is a series of short bursts instead of one marathon — the wall
# triggers on continuous session volume (~100-130 requests, runs 16-21), not daily total.
KEYWORDS_PER_CYCLE=4
# The search page is fixed at 20 notes but costs 1 request; the per-note details and
# comments behind it are the other ~97%. The crawler is patched to slice details+comments
# to the newest N of the page, so 10 roughly halves a keyword's request cost.
MAX_NOTES_PER_KEYWORD=10
# One comment page holds ~10, so 10 costs a single request per note; 20 paid a second
# page per note for tail comments that rarely name a stock.
MAX_COMMENTS_PER_NOTE=10
FETCH_INTERVAL_HOURS=8
# MediaCrawler sleeps this long after every note detail and every comment fetch (not just
# once per page), so it is the effective request rate. Its default of 3s got the account
# CAPTCHA-walled mid-cycle; 10s costs ~12 min per keyword.
CRAWL_SLEEP_SEC=10
# Per keyword process now (~4-5 min at the sliced volume) — a hung-browser backstop,
# not the cycle budget.
CRAWL_TIMEOUT_MIN=15
# Pause between per-keyword crawler processes. All keywords plus gaps must fit inside
# FETCH_INTERVAL_HOURS: 4 keywords × (~5 min + 12 min gap) ≈ 1 h. 0 disables the gaps.
KEYWORD_GAP_MIN=12
# XHS answers a flagged account with a CAPTCHA (461) and MediaCrawler retries every walled
# request, which only deepens the flag. Stop after this many; the notes already fetched are
# still ingested and the run is recorded as partial.
CAPTCHA_ABORT_COUNT=10
# After a CAPTCHA-walled run, scheduled cycles pause this long instead of retrying into
# the flag every interval. Manual "Fetch now" bypasses it (so you can test right after
# clearing the CAPTCHA in the browser). 0 disables.
RISK_COOLDOWN_HOURS=24
# Keep the replies XHS nests inside each comment's own response instead of discarding them.
# Costs no extra requests: the crawler already downloads them, and the loop that would page
# for the *rest* of a thread (one request per comment — the real account risk) is patched out.
ENABLE_SUB_COMMENTS=true
# Set true if your account lives on rednote.com (the international app) rather than
# mainland xiaohongshu.com. These are separate backends: the crawler must talk to
# webapi.rednote.com and use .rednote.com cookies, or every search returns
# 您当前登录的账号没有权限访问 even though the QR login succeeds.
XHS_INTERNATIONAL=false

# MediaCrawler hardcodes a macOS Chrome UA; on Windows that mismatch makes XHS log the
# session as an "unknown" device. Default below is a truthful Windows Chrome UA.
#BROWSER_USER_AGENT=

# Optional: reuse an already-logged-in browser session instead of QR login. Only needed
# if QR login works but searches are still refused. Log into the site your account is on
# → F12 → Network → click any request → Request Headers → copy the whole `cookie:` value
# (must include a1= and web_session=). It is a live session — treat it like a password;
# .env is gitignored, never commit or share it. Leave empty to use QR login.
XHS_COOKIES=

# Analysis
FRESH_WINDOW_HOURS=24
MIN_MENTIONS_FOR_ANALYSIS=2
MAX_ANALYZED_STOCKS=15
SLANG_SCAN_EVERY_N_CYCLES=20

# Price reality check (free Yahoo Finance quotes; the only non-XHS external request the app makes)
ENABLE_PRICE_QUOTES=true
QUOTE_REFRESH_MIN=30

# Paths (defaults are relative to repo root; override if needed)
#MEDIACRAWLER_DIR=C:\Coding\Test\xiaofinance\vendor\MediaCrawler
#UV_EXE=uv

# Server
HOST=127.0.0.1
PORT=8000
