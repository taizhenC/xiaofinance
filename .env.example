# DeepSeek API (leave empty for keyless fallback = quotes only, no summaries)
DEEPSEEK_API_KEY=

LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
SUMMARY_LANG=en

# Crawl
DISCOVERY_KEYWORDS=美股,纳斯达克,纳指,标普500,美股投资
MAX_NOTES_PER_KEYWORD=20
MAX_COMMENTS_PER_NOTE=20
FETCH_INTERVAL_HOURS=5
CRAWL_TIMEOUT_MIN=30
# Fetch reply threads under comments. More context for analysis, but noticeably
# more requests per note = slower crawls and higher account risk. Off by default.
ENABLE_SUB_COMMENTS=false
# Crawl with your real installed Chrome/Edge via CDP (isolated profile, real browser
# fingerprint). XHS blocks the search API for Playwright's bundled Chromium even after
# a successful login ("您当前登录的账号没有权限访问"). Falls back to bundled Chromium
# automatically if no Chrome/Edge is found.
ENABLE_CDP_MODE=true

# Analysis
FRESH_WINDOW_HOURS=24
MIN_MENTIONS_FOR_ANALYSIS=2
MAX_ANALYZED_STOCKS=15
SLANG_SCAN_EVERY_N_CYCLES=20

# Price reality check (free Yahoo Finance quotes; the only non-XHS external request the app makes)
ENABLE_PRICE_QUOTES=true
QUOTE_REFRESH_MIN=30

# Paths (defaults are relative to repo root; override if needed)
#MEDIACRAWLER_DIR=C:\Coding\Test\xiaofinance\vendor\MediaCrawler
#UV_EXE=uv

# Server
HOST=127.0.0.1
PORT=8000
